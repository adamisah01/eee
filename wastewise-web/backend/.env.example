# WasteWise Backend Environment Variables
# Copy this to .env and fill in real values

# Django
SECRET_KEY=change-me-to-a-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Supabase PostgreSQL or local PostgreSQL)
DATABASE_URL=postgres://wastewise:wastewise@localhost:5432/wastewise

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Africa's Talking (SMS + USSD)
AT_API_KEY=atsk_xxxxxxxxxxxxxxxxxxxxx
AT_USERNAME=sandbox
AT_SENDER_ID=WasteWise

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
